# Apache CORS headers — required for cPanel reverse proxy to Node.js
# This ensures Apache doesn't strip CORS headers before they reach the browser

<IfModule mod_headers.c>
    # Allow the specific production origins
    SetEnvIf Origin "^https://(www\.)?agadichoornam\.com$" CORS_ALLOW=1
    SetEnvIf Origin "^https://(www\.)?tweaki\.pw$"        CORS_ALLOW=1
    SetEnvIf Origin "^https://.*\.vercel\.app$"            CORS_ALLOW=1
    SetEnvIf Origin "^http://localhost(:\d+)?$"            CORS_ALLOW=1
    SetEnvIf Origin "^http://127\.0\.0\.1(:\d+)?$"        CORS_ALLOW=1

    Header always set Access-Control-Allow-Origin "%{HTTP_ORIGIN}e" env=CORS_ALLOW
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, PATCH"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

# Handle OPTIONS preflight requests immediately at Apache level
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]
